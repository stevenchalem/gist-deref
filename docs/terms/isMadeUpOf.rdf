    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is made up of</rdfs:label>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates something to a substance that it is made up of.</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Relates something to a substance that it is made up of.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A vase is made of clay; water is made up of hydrogen and oxygen.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is made up of</skos:prefLabel>
  </rdf:Description>
