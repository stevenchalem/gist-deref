  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b311">
    <owl:inverseOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/isDirectPartOf"/>
