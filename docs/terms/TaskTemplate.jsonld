            "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b320"
          }
        ]
      }
    },
    {
      "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b320",
      "@type": "owl:Restriction",
      "owl:onProperty": {
        "@id": "gist:hasGoal"
      },
      "owl:someValuesFrom": {
        "@id": "gist:Intention"
      }
    }
  ]
}