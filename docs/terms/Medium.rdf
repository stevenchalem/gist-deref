  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b283">
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/isRenderedOn"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Medium"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Medium">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Medium</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Category"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A physical material on which a work can be rendered, represented, or implemented.</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Paper, clay, a computer monitor.</skos:example>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A physical material on which a work can be rendered, represented, or implemented.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: Paper, clay, a computer monitor.</rdfs:comment>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Medium</skos:prefLabel>
  </rdf:Description>
