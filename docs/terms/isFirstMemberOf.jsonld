  "@graph": [
    {
      "@id": "gist:isFirstMemberOf",
      "@type": [
        "owl:FunctionalProperty",
        "owl:ObjectProperty"
      ],
      "rdfs:comment": [
        "DEFINITION: Relates the first member of an ordered collection to the collection.",
        "NOTE: Given the Open World Assumption, the absence of a predecessor does not entail that an ordered member is the first member of an ordered collection. This property is used to explicitly indicate the first member. Since ordered collections need not be strictly ordered, there can be more than one first member."
      ],
      "rdfs:domain": {
        "@id": "gist:OrderedMember"
      },
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "is first member of",
      "rdfs:range": {
        "@id": "gist:OrderedCollection"
      },
      "rdfs:subPropertyOf": {
        "@id": "gist:isMemberOf"
      },
      "skos:definition": "Relates the first member of an ordered collection to the collection.",
      "skos:prefLabel": "is first member of",
      "skos:scopeNote": "Given the Open World Assumption, the absence of a predecessor does not entail that an ordered member is the first member of an ordered collection. This property is used to explicitly indicate the first member. Since ordered collections need not be strictly ordered, there can be more than one first member."
    },
