    {
      "@id": "gist:OrderedMember",
      "@type": "owl:Class",
      "owl:equivalentClass": {
        "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b230"
      },
      "rdfs:comment": [
        "DEFINITION: A member of an ordered collection serving as a proxy for a real world item, which can appear in different orders in different collections. The ordered member appears in exactly one ordered collection.",
        "EXAMPLE: A person may rank 12th in the Boston Marathon but 29th in the New York City Marathon.",
        "NOTE: An ordered member points to the real world item via the providesOrderFor property. Ordering information is represented either as a number in a sequence, or by preceding or following another ordered member."
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "Ordered Member",
      "rdfs:subClassOf": {
        "@id": "gist:Component"
      },
      "skos:definition": "A member of an ordered collection serving as a proxy for a real world item, which can appear in different orders in different collections. The ordered member appears in exactly one ordered collection.",
      "skos:example": "A person may rank 12th in the Boston Marathon but 29th in the New York City Marathon.",
      "skos:prefLabel": "Ordered Member",
      "skos:scopeNote": "An ordered member points to the real world item via the providesOrderFor property. Ordering information is represented either as a number in a sequence, or by preceding or following another ordered member."
    },
