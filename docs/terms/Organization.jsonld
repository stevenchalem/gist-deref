      "rdfs:comment": [
        "EXAMPLE: Legal entities like companies; non-legal entities like clubs, committees, or departments.",
        "DEFINITION: A structured entity formed to achieve specific goals, typically involving members with defined roles.",
        "NOTE: While typically the members of organizations are people, in some cases they are other organizations; e.g., the members of the United Nations are country governments.",
        "NOTE: Not all organizations have members, e.g. shell companies."
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "Organization",
      "skos:definition": "A structured entity formed to achieve specific goals, typically involving members with defined roles.",
      "skos:example": "Legal entities like companies; non-legal entities like clubs, committees, or departments.",
      "skos:prefLabel": "Organization",
      "skos:scopeNote": [
        "Not all organizations have members, e.g. shell companies.",
        "While typically the members of organizations are people, in some cases they are other organizations; e.g., the members of the United Nations are country governments."
      ]
