  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/BundledCatalogItem">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Any combination of descriptions of things offered together.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A kit containing several parts offered together; a product plus a warranty.</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bundled Catalog Item</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/CatalogItem"/>
