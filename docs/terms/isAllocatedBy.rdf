  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/isAllocatedBy">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Relates something to whomever or whatever assigns or distributes it.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: The allocator may be a person, organization, or automated process.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A U.S. Social Security number is allocated by the U.S. Social Security Administration; the media type https://www.iana.org/assignments/media-types/text/csv is allocated by the Internet Assigned Numbers Authority (IANA).</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is allocated by</rdfs:label>
    <rdfs:range rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b394"/>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A U.S. Social Security number is allocated by the U.S. Social Security Administration; the media type https://www.iana.org/assignments/media-types/text/csv is allocated by the Internet Assigned Numbers Authority (IANA).</skos:example>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates something to whomever or whatever assigns or distributes it.</skos:definition>
    <gist:domainIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Category"/>
    <gist:domainIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/ID"/>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The allocator may be a person, organization, or automated process.</skos:scopeNote>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is allocated by</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
