    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property does not distinguish between things whose locations are stable and those whose locations change over time; e.g., a fire hydrant vs. a car.</skos:scopeNote>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has physical location</skos:prefLabel>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates something to its physical location.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: This property does not distinguish between things whose locations are stable and those whose locations change over time; e.g., a fire hydrant vs. a car.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Relates something to its physical location.</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has physical location</rdfs:label>
  </rdf:Description>
