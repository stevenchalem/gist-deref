  "@id": "gist:isProducedBy",
  "@type": "owl:ObjectProperty",
  "rdfs:comment": [
    "DEFINITION: Relates something to the thing that created, composed, or brought it into existence.",
    "EXAMPLE: A measurement is produced by a sensor.",
    "EXAMPLE: A deliverable is produces by a task.",
    "EXAMPLE: A painting is produced by a person."
  ],
