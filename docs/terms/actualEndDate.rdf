<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/actualEndDate">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Used for things where the precision of a date is sufficient, such as most projects, tasks, and the like. Recommended usage is to zero out the hours through microseconds to avoid spurious precision.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: The actual date that something ended, with precision of one day.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: '2021-06-01T00:00:00-06:00'^^xsd:dateTime</rdfs:comment>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The actual date that something ended, with precision of one day.</skos:definition>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/actualEndDateTime"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">actual end date</rdfs:label>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">'2021-06-01T00:00:00-06:00'^^xsd:dateTime</skos:example>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Used for things where the precision of a date is sufficient, such as most projects, tasks, and the like. Recommended usage is to zero out the hours through microseconds to avoid spurious precision.</skos:scopeNote>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">actual end date</skos:prefLabel>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/deathDate">
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/actualEndDate"/>
  </rdf:Description>
</rdf:RDF>
