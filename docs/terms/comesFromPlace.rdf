  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/comesFromPlace">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">comes from place</rdfs:label>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates something to its place of origin.</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdfs:range rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b340"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Relates something to its place of origin.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A letter has a return address indicating its origin; a delivery route originates at a distribution center; a trail originates at the trailhead.</rdfs:comment>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">comes from place</skos:prefLabel>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A letter has a return address indicating its origin; a delivery route originates at a distribution center; a trail originates at the trailhead.</skos:example>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
