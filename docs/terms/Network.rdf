  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Network">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A composite consisting of nodes connected by links.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A physical network could include connected computers or routers, whereas a social network would consist of related person or organization members (or their proxies, such as accounts).</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Network</skos:prefLabel>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Network</rdfs:label>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A composite consisting of nodes connected by links.</skos:definition>
    <owl:equivalentClass rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b185"/>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A physical network could include connected computers or routers, whereas a social network would consist of related person or organization members (or their proxies, such as accounts).</skos:example>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Composite"/>
  </rdf:Description>
