    <rdf:first rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/TemporalRelation"/>
    <rdf:rest rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b21"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b21">
    <rdf:first rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b17"/>
    <rdf:rest rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b22"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/isAssignmentOf">
    <gist:domainIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Assignment"/>
