            "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b291"
          }
        ]
      }
    },
    {
      "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b291",
      "@type": "owl:Restriction",
      "owl:onProperty": {
        "@id": "gist:plannedStartDateTime"
      },
      "owl:someValuesFrom": {
        "@id": "xsd:dateTime"
      }
    },
    {
      "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b295",
      "rdf:first": {
        "@id": "gist:ScheduledEvent"
      },
      "rdf:rest": {
        "@list": [
          {
            "@id": "gist:Task"
          }
        ]
      }
    },
    {
      "@id": "gist:ScheduledTask",
      "rdfs:subClassOf": {
        "@id": "gist:ScheduledEvent"
      }
    }
  ]
}