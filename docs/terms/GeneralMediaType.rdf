    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Audio, still image, video, textual, physical (e.g., a statue), performance (e.g., a play), oil or pastel for a painting.</skos:example>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The real-world media type for content.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">General Media Type</skos:prefLabel>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: The real-world media type for content.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: Audio, still image, video, textual, physical (e.g., a statue), performance (e.g., a play), oil or pastel for a painting.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Category"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">General Media Type</rdfs:label>
  </rdf:Description>
