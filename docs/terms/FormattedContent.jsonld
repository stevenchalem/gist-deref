      },
      "skos:definition": "Content encoded in a specific format, but existing as data independent of any particular physical medium.",
      "skos:example": "A document in PDF format; an image in JPEG format.",
      "skos:prefLabel": "Formatted Content",
      "skos:scopeNote": "Each instance of formatted content is a distinct formatting of some Content. Thus, a PDF-formatted version and an HTML-formatted version of the same content are separate instances of formatted content."
    },
