<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:gist="https://w3id.org/semanticarts/ns/ontology/gist/"
   xmlns:owl="http://www.w3.org/2002/07/owl#"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/uniqueText">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Note that the uniqueness only goes in one direction: a product catalog number might also be an employee ID.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: The unique string value of some content object, to be used when there is no possibility of having more than one value.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: The unique string for a vehicle identification number.</rdfs:comment>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The unique string value of some content object, to be used when there is no possibility of having more than one value.</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <gist:domainIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Text"/>
    <gist:domainIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/MediaType"/>
    <gist:domainIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/ID"/>
    <gist:domainIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Tag"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">unique text</skos:prefLabel>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">unique text</rdfs:label>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The unique string for a vehicle identification number.</skos:example>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Note that the uniqueness only goes in one direction: a product catalog number might also be an employee ID.</skos:scopeNote>
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/containedText"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b172">
    <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/uniqueText"/>
