  "@id": "gist:EventSpecification",
  "@type": "owl:Class",
  "rdfs:comment": [
    "NOTE: This concept is useful for risk assessment and insurance policies.",
    "EXAMPLE: An insurance company defines the characteristics of a weather event that must be satisfied for it to qualify as a hail storm covered in its homeowner's policy; a bank defines the point at which a borrower defaults on a loan.",
    "DEFINITION: A characterization of an event that might happen."
  ],
  "rdfs:isDefinedBy": {
    "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
  },
  "rdfs:label": "Event Specification",
