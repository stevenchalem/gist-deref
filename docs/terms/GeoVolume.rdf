  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/GeoVolume">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: An oil reservoir, the body of a lake, or an airspace.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A three-dimensional space on or near the surface of the Earth.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A three-dimensional space on or near the surface of the Earth.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An oil reservoir, the body of a lake, or an airspace.</skos:example>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Geographic Volume</rdfs:label>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/GeoLocation"/>
    <owl:equivalentClass rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b123"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Geographic Volume</skos:prefLabel>
  </rdf:Description>
