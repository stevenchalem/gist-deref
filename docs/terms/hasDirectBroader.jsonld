    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@id": "gist:hasDirectBroader",
  "@type": "owl:ObjectProperty",
  "rdfs:comment": [
    "DEFINITION: Relates a thing to another thing with a broader meaning, when there is no intermediate between them.",
    "NOTE: Unlike gist:hasBroader, this property is not transitive. It is safest to use this property when semantic directness is inherent in the relationship. Otherwise, there is a risk of making a hasDirectBroader assertion and then later inserting an intermediate part; this will result in making an asserted triple false even though there was no change in the world. When in doubt, use the transitive version gist:hasBroader."
  ],
  "rdfs:isDefinedBy": {
    "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
  },
  "rdfs:label": "has direct broader",
  "rdfs:subPropertyOf": {
    "@id": "gist:hasBroader"
  },
  "skos:definition": "Relates a thing to another thing with a broader meaning, when there is no intermediate between them.",
  "skos:prefLabel": "has direct broader",
  "skos:scopeNote": "Unlike gist:hasBroader, this property is not transitive. It is safest to use this property when semantic directness is inherent in the relationship. Otherwise, there is a risk of making a hasDirectBroader assertion and then later inserting an intermediate part; this will result in making an asserted triple false even though there was no change in the world. When in doubt, use the transitive version gist:hasBroader."
}