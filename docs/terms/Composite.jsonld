    {
      "@id": "gist:Composite",
      "@type": "owl:Class",
      "rdfs:comment": [
        "DEFINITION: Something which is made up of various parts or elements that are independently identifiable.",
        "NOTE: This class is not disjoint with gist:Component, because a composite can itself be a component of a larger composite.",
        "NOTE: This is an abstract class that will not be directly instantiated.",
        "EXAMPLE: A library (collection of books); a network of pipes and valves; a computer network of routers and computers.",
        "NOTE: Some composites, like systems, networks, and ordered collections, have internal organization, while others, such as unordered collections, typically do not."
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "Composite",
      "skos:definition": "Something which is made up of various parts or elements that are independently identifiable.",
      "skos:example": "A library (collection of books); a network of pipes and valves; a computer network of routers and computers.",
      "skos:prefLabel": "Composite",
      "skos:scopeNote": [
        "This class is not disjoint with gist:Component, because a composite can itself be a component of a larger composite.",
        "Some composites, like systems, networks, and ordered collections, have internal organization, while others, such as unordered collections, typically do not.",
        "This is an abstract class that will not be directly instantiated."
      ]
