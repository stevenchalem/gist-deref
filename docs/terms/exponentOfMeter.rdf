  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/exponentOfMeter">
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The exponent of meter in a product of powers of base units.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In the equation '1 microgram per milliliter = 0.001 x kilogram per meterCubed'&#13;
&#13;
		the conversion factor for microgram per milliliter is 0.001&#13;
		the exponent of kilogram is 1&#13;
		the exponent of meter is -3&#13;
		all other exponents are zero&#13;
&#13;
		Every member of a unit group containing microgram per milliliter must be a multiple of kilogram per meterCubed.</skos:example>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">exponent of meter</rdfs:label>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: In the equation '1 microgram per milliliter = 0.001 x kilogram per meterCubed'&#13;
&#13;
		the conversion factor for microgram per milliliter is 0.001&#13;
		the exponent of kilogram is 1&#13;
		the exponent of meter is -3&#13;
		all other exponents are zero&#13;
&#13;
		Every member of a unit group containing microgram per milliliter must be a multiple of kilogram per meterCubed.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: The exponent of meter in a product of powers of base units.</rdfs:comment>
    <rdfs:domain rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b361"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">exponent of meter</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b362">
    <rdf:rest rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b363"/>
