  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/ProductCategory">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Any of many ways of categorizing products.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: Automobile models, NATO product codes.</rdfs:comment>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Automobile models, NATO product codes.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Product Category</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Category"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Product Category</rdfs:label>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Any of many ways of categorizing products.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b274">
