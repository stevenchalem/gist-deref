    },
    {
      "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b12",
      "owl:inverseOf": {
        "@id": "gist:isDirectPartOf"
      }
    },
    {
      "@id": "gist:isDirectPartOf",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": [
        "NOTE: Because the part has independent existence, there is no cascading delete.",
        "DEFINITION: The relationship between a part and a whole where the part has independent existence and there are no other parts in between.",
        "NOTE: It is safest to use this property when semantic directness is inherent in the relationship, rather than simply expressing a chosen granularity. For example, a spark plug is a direct part of an engine block; there cannot be any intermediate parts. Otherwise, there is a risk of making an isDirectPartOf assertion and then later inserting an intermediate part; this will result in making an asserted triple false even though there was no change in the world. When in doubt, use the transitive version gist:isPartOf."
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "is direct part of",
      "rdfs:subPropertyOf": {
        "@id": "gist:isPartOf"
      },
      "skos:definition": "The relationship between a part and a whole where the part has independent existence and there are no other parts in between.",
      "skos:prefLabel": "is direct part of",
      "skos:scopeNote": [
        "It is safest to use this property when semantic directness is inherent in the relationship, rather than simply expressing a chosen granularity. For example, a spark plug is a direct part of an engine block; there cannot be any intermediate parts. Otherwise, there is a risk of making an isDirectPartOf assertion and then later inserting an intermediate part; this will result in making an asserted triple false even though there was no change in the world. When in doubt, use the transitive version gist:isPartOf.",
        "Because the part has independent existence, there is no cascading delete."
      ]
    }
  ]
}