  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/ContemporaryEvent">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">When the event actually ends, it will cease being contemporary.</skos:scopeNote>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An event that has started but has not yet ended.</skos:definition>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: An event that has started but has not yet ended.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: When the event actually ends, it will cease being contemporary.</rdfs:comment>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contemporary Event</skos:prefLabel>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Event"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Contemporary Event</rdfs:label>
    <owl:equivalentClass rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b47"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b48">
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/actualStartDateTime"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b49">
    <owl:maxCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:maxCardinality>
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/actualEndDateTime"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b52">
