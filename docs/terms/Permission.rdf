  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Permission">
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Intention"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A description of things one is permitted to do.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: Permission could be broad, such as free speech, but more often is very specific, such as the right to enter a particular property.</rdfs:comment>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A description of things one is permitted to do.</skos:definition>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Permission</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Permission could be broad, such as free speech, but more often is very specific, such as the right to enter a particular property.</skos:example>
    <owl:equivalentClass rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b247"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Permission</skos:prefLabel>
  </rdf:Description>
