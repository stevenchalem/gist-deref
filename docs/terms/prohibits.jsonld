  "@graph": [
    {
      "@id": "gist:prevents",
      "gist:isSupersededBy": {
        "@id": "gist:prohibits"
      },
      "owl:equivalentProperty": {
        "@id": "gist:prohibits"
      }
    },
    {
      "@id": "gist:prohibits",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": [
        "DEFINITION: Relates an intention to a behavior that it forbids or seeks to prevent.",
        "NOTE: A behavior can be prohibited without being prevented. For example, a speed limit may prohibit driving faster than a stated speed but does not always succeed in preventing drivers from exceeding that speed.",
        "EXAMPLE: Private property laws prohibit someone from entering private land marked with a 'No Trespassing' sign.",
        "EXAMPLE: A city ordinance prohibits jaywalking."
      ],
      "rdfs:domain": {
        "@id": "gist:Intention"
      },
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "prohibits",
      "rdfs:range": {
        "@id": "gist:Behavior"
      },
      "skos:definition": "Relates an intention to a behavior that it forbids or seeks to prevent.",
      "skos:example": [
        "A city ordinance prohibits jaywalking.",
        "Private property laws prohibit someone from entering private land marked with a 'No Trespassing' sign."
      ],
      "skos:prefLabel": "prohibits",
      "skos:scopeNote": "A behavior can be prohibited without being prevented. For example, a speed limit may prohibit driving faster than a stated speed but does not always succeed in preventing drivers from exceeding that speed."
    }
  ]
