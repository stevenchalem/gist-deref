  "@id": "gist:isSupersededBy",
  "@type": "owl:AnnotationProperty",
  "rdfs:comment": [
    "DEFINITION: Relates a deprecated term to a term that replaces it, which is either an exact (in the case of simple renaming) or approximate (in the case of renaming and some semantic change) semantic match.",
    "EXAMPLE: gist:connectedTo was superseded by gist:isConnectedTo (renaming with no semantic change)."
  ],
  "rdfs:isDefinedBy": {
    "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
  },
  "rdfs:label": "is superseded by",
  "skos:definition": "Relates a deprecated term to a term that replaces it, which is either an exact (in the case of simple renaming) or approximate (in the case of renaming and some semantic change) semantic match.",
  "skos:example": "gist:connectedTo was superseded by gist:isConnectedTo (renaming with no semantic change).",
  "skos:prefLabel": "is superseded by"
}