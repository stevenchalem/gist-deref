    {
      "@id": "gist:hasParticipant",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": [
        "EXAMPLE: An event of transferring money has a participating account that receives the money.",
        "DEFINITION: Relates something (e.g. an agreement) to things that play a role, or take part or are otherwise involved in some way.",
        "NOTE: The thing with participants will often be an agreement, event or obligation. Participation does not imply agency.",
        "NOTE: This will most often be used as an abstract property. Use subproperties that indicate the nature of the participation (e.g. hasBorrower, hasVenue)."
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "has participant",
      "skos:definition": "Relates something (e.g. an agreement) to things that play a role, or take part or are otherwise involved in some way.",
      "skos:example": "An event of transferring money has a participating account that receives the money.",
      "skos:prefLabel": "has participant",
      "skos:scopeNote": [
        "This will most often be used as an abstract property. Use subproperties that indicate the nature of the participation (e.g. hasBorrower, hasVenue).",
        "The thing with participants will often be an agreement, event or obligation. Participation does not imply agency."
      ]
    },
    {
      "@id": "gist:hasRecipient",
