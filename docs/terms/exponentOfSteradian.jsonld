  "@graph": [
    {
      "@id": "gist:exponentOfSteradian",
      "@type": "owl:DatatypeProperty",
      "rdfs:comment": [
        "DEFINITION: The exponent of steradian in a product of powers of base units.",
        "NOTE: Steradian is a measure of solid angle.",
        "EXAMPLE: In the equation '1 watt per square meter steradian = 1 x kilogram per secondCubed steradian'\r\n\r\n\t\tthe conversion factor for watt per square meter steradian is 1\r\n\t\tthe exponent of kilogram is 1\r\n\t\tthe exponent of second is -3\r\n\t\tthe exponent of steradian is -1\r\n\t\tall other exponents are zero\r\n\r\n\t\tEvery member of a unit group containing watt per square meter steradian must a multiple of kilogram per secondCubed steradian."
      ],
      "rdfs:domain": {
        "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b379"
      },
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "exponent of steradian",
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:definition": "The exponent of steradian in a product of powers of base units.",
      "skos:example": "In the equation '1 watt per square meter steradian = 1 x kilogram per secondCubed steradian'\r\n\r\n\t\tthe conversion factor for watt per square meter steradian is 1\r\n\t\tthe exponent of kilogram is 1\r\n\t\tthe exponent of second is -3\r\n\t\tthe exponent of steradian is -1\r\n\t\tall other exponents are zero\r\n\r\n\t\tEvery member of a unit group containing watt per square meter steradian must a multiple of kilogram per secondCubed steradian.",
      "skos:prefLabel": "exponent of steradian",
      "skos:scopeNote": "Steradian is a measure of solid angle."
    },
