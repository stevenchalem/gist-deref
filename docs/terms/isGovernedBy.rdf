  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/isGovernedBy">
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A country geographic region is governed by a country government; the installation and use of software is governed by a license.</skos:example>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is governed by</rdfs:label>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates an entity to another entity that controls, directs, determines or has a guiding influence or authority over it.</skos:definition>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A country geographic region is governed by a country government; the installation and use of software is governed by a license.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Relates an entity to another entity that controls, directs, determines or has a guiding influence or authority over it.</rdfs:comment>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is governed by</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
  </rdf:Description>
