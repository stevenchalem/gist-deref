      },
      "rdfs:comment": [
        "DEFINITION: Relates an offer to the thing expected in return for the offered item.",
        "NOTE: This will most often be an amount of money, but could be anything of value, as in swaps.",
        "EXAMPLE: A vendor makes an offer to receive a particular amount of money in exchange for the offered product; an offer to receive a home in exchange for an amount of money."
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "offers to receive",
