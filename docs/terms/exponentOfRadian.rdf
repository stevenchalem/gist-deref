>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/exponentOfRadian">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: The exponent of radian in a product of powers of base units.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: In the equation '1 revolution = 6.283 x radian'&#13;
&#13;
		the conversion factor for revolution is 6.283&#13;
		the exponent of radian is 1&#13;
		all other exponents are zero&#13;
&#13;
		Every member of a unit group containing revolution must be a multiple of radian.</rdfs:comment>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The exponent of radian in a product of powers of base units.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In the equation '1 revolution = 6.283 x radian'&#13;
&#13;
		the conversion factor for revolution is 6.283&#13;
		the exponent of radian is 1&#13;
		all other exponents are zero&#13;
&#13;
		Every member of a unit group containing revolution must be a multiple of radian.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">exponent of radian</skos:prefLabel>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <rdfs:domain rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b373"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">exponent of radian</rdfs:label>
  </rdf:Description>
