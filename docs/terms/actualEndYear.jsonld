{
  "@context": {
    "dcterms": "http://purl.org/dc/terms/",
    "gist": "https://w3id.org/semanticarts/ns/ontology/gist/",
    "gistd": "https://w3id.org/semanticarts/ns/data/gist/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@id": "gist:actualEndYear",
  "@type": "owl:DatatypeProperty",
  "rdfs:comment": [
    "DEFINITION: The actual date that something ended, with precision of one year.",
    "EXAMPLE: '2021-01-01T00:00:00-06:00'^^xsd:dateTime",
    "EXAMPLE: The tenure of the previous chairman of the board ended in 2021.",
    "NOTE: Used for things where the precision of a year is sufficient. Recommended usage is to zero out the hours through microseconds to avoid spurious precision. Note that it is not valid to zero out months and days, so arbitrary values must be included."
  ],
  "rdfs:isDefinedBy": {
    "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
  },
  "rdfs:label": "actual end year",
  "rdfs:range": {
    "@id": "xsd:dateTime"
  },
  "rdfs:subPropertyOf": {
    "@id": "gist:actualEndDateTime"
  },
  "skos:definition": "The actual date that something ended, with precision of one year.",
  "skos:example": [
    "The tenure of the previous chairman of the board ended in 2021.",
    "'2021-01-01T00:00:00-06:00'^^xsd:dateTime"
  ],
  "skos:prefLabel": "actual end year",
  "skos:scopeNote": "Used for things where the precision of a year is sufficient. Recommended usage is to zero out the hours through microseconds to avoid spurious precision. Note that it is not valid to zero out months and days, so arbitrary values must be included."
}