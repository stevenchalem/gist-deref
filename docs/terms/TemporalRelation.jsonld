  "@graph": [
    {
      "@id": "gist:Assignment",
      "rdfs:subClassOf": {
        "@id": "gist:TemporalRelation"
      }
    },
    {
      "@id": "gist:TemporalRelation",
      "@type": "owl:Class",
      "rdfs:comment": [
        "DEFINITION: A relationship existing for a period of time.",
        "EXAMPLE: The relationship between a person and their employer; the relationship between a person or business and an address.",
        "NOTE: A temporal relation must have a minimum of two participants. For example, both the employer and the employee are participants in a temporal relation representing a period of employment. Note that 'participant' does not imply agency; a non-sentient being can participate in a temporal relation. For example, both a person and a house could be participants in a hypothetical relation 'lives at.'"
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "Temporal Relation",
      "rdfs:subClassOf": [
        {
          "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b323"
        },
        {
          "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b324"
        }
      ],
      "skos:definition": "A relationship existing for a period of time.",
      "skos:example": "The relationship between a person and their employer; the relationship between a person or business and an address.",
      "skos:prefLabel": "Temporal Relation",
      "skos:scopeNote": "A temporal relation must have a minimum of two participants. For example, both the employer and the employee are participants in a temporal relation representing a period of employment. Note that 'participant' does not imply agency; a non-sentient being can participate in a temporal relation. For example, both a person and a house could be participants in a hypothetical relation 'lives at.'"
    },
    {
      "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b323",
      "@type": "owl:Restriction",
      "owl:cardinality": {
