  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/OrderedCollection">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A collection whose members are ordered in some way.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Includes partially ordered collections as well as collections in which members occupy the same position in a 'tie.' All members of an ordered collection are ordered members.</rdfs:comment>
    <owl:equivalentClass rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b217"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Collection"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ordered Collection</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Includes partially ordered collections as well as collections in which members occupy the same position in a 'tie.' All members of an ordered collection are ordered members.</skos:scopeNote>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Ordered Collection</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A collection whose members are ordered in some way.</skos:definition>
  </rdf:Description>
