  "@id": "gist:hasUnitGroup",
  "@type": "owl:ObjectProperty",
  "rdfs:comment": [
    "DEFINITION: Relates an aspect to a unit group. The aspect can be measured using any of the members of the unit group.",
    "EXAMPLE: The aspect distance can have a unit group that includes the units meter, inch, foot, etc."
  ],
  "rdfs:domain": {
    "@id": "gist:Aspect"
  },
  "rdfs:isDefinedBy": {
    "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
  },
  "rdfs:label": "has unit group",
  "rdfs:range": {
    "@id": "gist:UnitGroup"
  },
  "skos:definition": "Relates an aspect to a unit group. The aspect can be measured using any of the members of the unit group.",
  "skos:example": "The aspect distance can have a unit group that includes the units meter, inch, foot, etc.",
  "skos:prefLabel": "has unit group"
}