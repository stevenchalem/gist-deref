      "@id": "gist:hasNavigationalParent",
      "@type": "owl:ObjectProperty",
      "rdfs:comment": [
        "DEFINITION: Relates a child category to a parent category in an informal (e.g., faceted) hierarchy.",
        "EXAMPLE: Refrigerator handles are not refrigerators, but it may be useful to represent their relationship hierarchically for a faceted UI filter."
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "has navigational parent",
      "skos:definition": "Relates a child category to a parent category in an informal (e.g., faceted) hierarchy.",
      "skos:example": "Refrigerator handles are not refrigerators, but it may be useful to represent their relationship hierarchically for a faceted UI filter.",
      "skos:prefLabel": "has navigational parent"
    },
    {
      "@id": "gist:hasUniqueNavigationalParent",
      "rdfs:subPropertyOf": {
        "@id": "gist:hasNavigationalParent"
      }
    }
  ]
