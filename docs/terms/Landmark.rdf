    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/PhysicalIdentifiableItem"/>
    <skos:editorialNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">See guidance on removing the term in the next major release at https://github.com/semanticarts/gist/issues/947#issuecomment-1679566885.</skos:editorialNote>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Something permanently attached to the Earth.</rdfs:comment>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Landmark</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Something permanently attached to the Earth.</skos:definition>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b158">
