    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In the US, drivers must drive on the right side of the road.</skos:example>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The obligation of a person or organization to behave in a certain way.</skos:definition>
