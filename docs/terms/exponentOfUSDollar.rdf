  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/exponentOfUSDollar">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">exponent of US dollar</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In the equation '1 million dollars per week = 1.65344 x dollar per second'&#13;
&#13;
		the conversion factor for million dollars per week is 1.65344&#13;
		the exponent of US Dollar is 1&#13;
		the exponent of second is -1&#13;
		all other exponents are zero&#13;
&#13;
		Every member of a unit group containing million dollars per week must be a multiple of dollar per second.</skos:example>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: The exponent of US Dollar in a product of powers of base units.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: The factors for converting from one currency to another change constantly.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: In the equation '1 million dollars per week = 1.65344 x dollar per second'&#13;
&#13;
		the conversion factor for million dollars per week is 1.65344&#13;
		the exponent of US Dollar is 1&#13;
		the exponent of second is -1&#13;
		all other exponents are zero&#13;
&#13;
		Every member of a unit group containing million dollars per week must be a multiple of dollar per second.</rdfs:comment>
    <rdfs:domain rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b382"/>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The factors for converting from one currency to another change constantly.</skos:scopeNote>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">exponent of US dollar</rdfs:label>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The exponent of US Dollar in a product of powers of base units.</skos:definition>
  </rdf:Description>
