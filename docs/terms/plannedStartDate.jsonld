{
  "@context": {
    "dcterms": "http://purl.org/dc/terms/",
    "gist": "https://w3id.org/semanticarts/ns/ontology/gist/",
    "gistd": "https://w3id.org/semanticarts/ns/data/gist/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@id": "gist:plannedStartDate",
  "@type": "owl:DatatypeProperty",
  "rdfs:comment": [
    "DEFINITION: The date that something is or was planned to start, with precision of one day.",
    "NOTE: Used for anything with a planned start date, such as when a lease will start, when a configuration becomes available, etc. Typically a planned date is in the future when first captured, but when tasks run late, we leave the plan where it was and compare it to the actual. Recommended usage is to zero out the hours through microseconds to avoid spurious precision.",
    "EXAMPLE: '2021-06-01T00:00:00-06:00'^^xsd:dateTime"
  ],
  "rdfs:isDefinedBy": {
    "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
  },
  "rdfs:label": "planned start date",
  "rdfs:range": {
    "@id": "xsd:dateTime"
  },
  "rdfs:subPropertyOf": {
    "@id": "gist:plannedStartDateTime"
  },
  "skos:definition": "The date that something is or was planned to start, with precision of one day.",
  "skos:example": "'2021-06-01T00:00:00-06:00'^^xsd:dateTime",
  "skos:prefLabel": "planned start date",
  "skos:scopeNote": "Used for anything with a planned start date, such as when a lease will start, when a configuration becomes available, etc. Typically a planned date is in the future when first captured, but when tasks run late, we leave the plan where it was and compare it to the actual. Recommended usage is to zero out the hours through microseconds to avoid spurious precision."
}