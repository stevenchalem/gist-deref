    {
      "@id": "gist:Offer",
      "@type": "owl:Class",
      "owl:equivalentClass": {
        "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b202"
      },
      "rdfs:comment": [
        "DEFINITION: A contingent commitment to buy, sell, swap or provide one or more described or identified goods or services in exchange for another (or others).",
        "EXAMPLE: An offer to sell a book for a given price; an offer to purchase real estate for a particular price; an offer to swap a sea kayak for a mountain bike; currency exchange. A donation may be modeled as an offer to receive money typically in exchange for $0.00, but sometimes for items of value such as coffee mugs or T-shirts.",
        "NOTE: Dates on an offer represent the time period the offer is valid for, as in '25% off through October 25, 2025.'"
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "Offer",
      "rdfs:subClassOf": {
        "@id": "gist:ContingentObligation"
      },
      "skos:definition": "A contingent commitment to buy, sell, swap or provide one or more described or identified goods or services in exchange for another (or others).",
      "skos:example": "An offer to sell a book for a given price; an offer to purchase real estate for a particular price; an offer to swap a sea kayak for a mountain bike; currency exchange. A donation may be modeled as an offer to receive money typically in exchange for $0.00, but sometimes for items of value such as coffee mugs or T-shirts.",
      "skos:prefLabel": "Offer",
      "skos:scopeNote": "Dates on an offer represent the time period the offer is valid for, as in '25% off through October 25, 2025.'"
    },
