  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/startDateTime">
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/atDateTime"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: This property is neutral along two dimensions: precision (e.g., day, second, millisecond) and actual vs. planned. As such, it will generally not be asserted directly except in special cases (e.g., for time intervals).</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: The date and time that something starts.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Values of predicates with different precisions can be compared since they are all formally xsd:datetimes.</rdfs:comment>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">This property is neutral along two dimensions: precision (e.g., day, second, millisecond) and actual vs. planned. As such, it will generally not be asserted directly except in special cases (e.g., for time intervals).</skos:scopeNote>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Values of predicates with different precisions can be compared since they are all formally xsd:datetimes.</skos:scopeNote>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">start date time</rdfs:label>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The date and time that something starts.</skos:definition>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">start date time</skos:prefLabel>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b323">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/startDateTime"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b332">
    <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
