      "rdfs:comment": [
        "DEFINITION: A geographic region governed by at least one government organization.",
        "NOTE: Geographic regions do not need not be physically contiguous in order to constitute a governed geographic region; e.g., Alaska and Hawaii are part of the region governed by the United States."
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "Governed Geographic Region",
      "rdfs:subClassOf": {
