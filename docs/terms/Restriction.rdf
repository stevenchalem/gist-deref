  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Restriction">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A description of things one is prevented from doing.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: In the US, tax laws restrict the amount of money a person can put in retirement accounts over the course of a year.</rdfs:comment>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A description of things one is prevented from doing.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">In the US, tax laws restrict the amount of money a person can put in retirement accounts over the course of a year.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Restriction</skos:prefLabel>
    <owl:equivalentClass rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b286"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Intention"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Restriction</rdfs:label>
  </rdf:Description>
