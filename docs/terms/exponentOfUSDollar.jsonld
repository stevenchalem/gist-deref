  "@graph": [
    {
      "@id": "gist:exponentOfUSDollar",
      "@type": "owl:DatatypeProperty",
      "rdfs:comment": [
        "DEFINITION: The exponent of US Dollar in a product of powers of base units.",
        "NOTE: The factors for converting from one currency to another change constantly.",
        "EXAMPLE: In the equation '1 million dollars per week = 1.65344 x dollar per second'\r\n\r\n\t\tthe conversion factor for million dollars per week is 1.65344\r\n\t\tthe exponent of US Dollar is 1\r\n\t\tthe exponent of second is -1\r\n\t\tall other exponents are zero\r\n\r\n\t\tEvery member of a unit group containing million dollars per week must be a multiple of dollar per second."
      ],
      "rdfs:domain": {
        "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b382"
      },
      "rdfs:isDefinedBy": {
