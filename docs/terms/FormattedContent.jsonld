      },
      "rdfs:comment": [
        "DEFINITION: Content encoded in a specific format, but existing as data independent of any particular physical medium.",
        "NOTE: Each instance of formatted content is a distinct formatting of some Content. Thus, a PDF-formatted version and an HTML-formatted version of the same content are separate instances of formatted content.",
        "EXAMPLE: A document in PDF format; an image in JPEG format."
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "Formatted Content",
