  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Landmark">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Landmark</rdfs:label>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
