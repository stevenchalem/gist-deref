  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/hasParty">
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/hasParticipant"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Subproperties may be defined to describe specific parties, such as hasLender and hasBorrower for a loan.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Relates an event, agreement, or obligation to a participating person or organization.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: Loan agreements have lender and borrower parties.</rdfs:comment>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Subproperties may be defined to describe specific parties, such as hasLender and hasBorrower for a loan.</skos:scopeNote>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Loan agreements have lender and borrower parties.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has party</skos:prefLabel>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates an event, agreement, or obligation to a participating person or organization.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:range rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b391"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has party</rdfs:label>
  </rdf:Description>
