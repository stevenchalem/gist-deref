  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/DegreeOfCommitment">
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Degree Of Commitment</rdfs:label>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A car rental typically has a lower degree of commitment than an airfare reservation.</skos:example>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Category"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
