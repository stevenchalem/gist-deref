<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/actualEndMicrosecond">
    <rdfs:subPropertyOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/actualEndDateTime"/>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">'2021-06-01T08:03:27.12324-6:00'^^xsd:dateTime</skos:example>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: The actual time that something ended, expressed as a system time used for timestamps.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: '2021-06-01T08:03:27.12324-6:00'^^xsd:dateTime</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: A system time will be as precise as the system can supply, typically at least milliseconds, sometimes microseconds. The convention for timestamps, such as recording a transaction, is to specify just the end point; the start time is rarely needed.</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">actual end microsecond</rdfs:label>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A system time will be as precise as the system can supply, typically at least milliseconds, sometimes microseconds. The convention for timestamps, such as recording a transaction, is to specify just the end point; the start time is rarely needed.</skos:scopeNote>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The actual time that something ended, expressed as a system time used for timestamps.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">actual end microsecond</skos:prefLabel>
  </rdf:Description>
</rdf:RDF>
