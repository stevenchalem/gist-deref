  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/IntergovernmentalOrganization">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: The United Nations, the European Union, the Metropolitan Transit Authority.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: An organization whose members are government organizations. This can comprise regional, municipal, state/province, or national level entities.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intergovernmental Organization</skos:prefLabel>
    <owl:equivalentClass rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b150"/>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An organization whose members are government organizations. This can comprise regional, municipal, state/province, or national level entities.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The United Nations, the European Union, the Metropolitan Transit Authority.</skos:example>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Organization"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intergovernmental Organization</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b154">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b151"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b151">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b152"/>
    <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:minQualifiedCardinality>
    <owl:onClass rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/GovernmentOrganization"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b150">
