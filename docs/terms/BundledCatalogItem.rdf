    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A kit containing several parts offered together; a product plus a warranty.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bundled Catalog Item</skos:prefLabel>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Any combination of descriptions of things offered together.</skos:definition>
  </rdf:Description>
