>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b161">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/birthDate"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b163">
    <rdf:first rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b160"/>
    <rdf:rest rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b164"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b160">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/LivingThing"/>
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/hasBiologicalParent"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b254">
    <rdf:first rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/LivingThing"/>
    <rdf:rest rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b255"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/LivingThing">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Something that is currently, or at some point in time was, alive.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: Negative examples: fictional life forms such as unicorns or Mickey Mouse.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: Not all life forms have exactly two parents, so the restriction only specifies a minimum of one.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A cat, a mushroom, a tree.</rdfs:comment>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Living Thing</rdfs:label>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Not all life forms have exactly two parents, so the restriction only specifies a minimum of one.</skos:scopeNote>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Something that is currently, or at some point in time was, alive.</skos:definition>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A cat, a mushroom, a tree.</skos:example>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Negative examples: fictional life forms such as unicorns or Mickey Mouse.</skos:example>
    <owl:equivalentClass rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b159"/>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/PhysicalIdentifiableItem"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Living Thing</skos:prefLabel>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b253">
    <owl:someValuesFrom rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Person"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/hasBiologicalParent"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b162">
    <rdf:rest rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b163"/>
    <rdf:first rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/PhysicalIdentifiableItem"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/hasBiologicalParent">
    <rdfs:range rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/LivingThing"/>
    <rdfs:domain rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/LivingThing"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/Person">
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/LivingThing"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b255">
    <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    <rdf:first rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b253"/>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b159">
