  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b320">
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/hasGoal"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:someValuesFrom rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Intention"/>
  </rdf:Description>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/hasGoal">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Relates something to the end towards which it directs effort.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: The sales division of a company has the goal of acquiring new customers and contracts.</rdfs:comment>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates something to the end towards which it directs effort.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The sales division of a company has the goal of acquiring new customers and contracts.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has goal</skos:prefLabel>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">has goal</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b316">
    <owl:someValuesFrom rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Intention"/>
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/hasGoal"/>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
  </rdf:Description>
</rdf:RDF>
