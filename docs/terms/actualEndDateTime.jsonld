      "rdfs:comment": [
        "DEFINITION: The actual date and time that something ended, with no implied precision.",
        "NOTE: This is an abstraction over the various precisions of actual end time, and is not expected to be asserted directly. Values of predicates with different precisions can be compared since they are all formally xsd:datetimes."
      ],
      "rdfs:isDefinedBy": {
