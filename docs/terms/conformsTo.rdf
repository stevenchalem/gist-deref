<?xml version="1.0" encoding="utf-8"?>
<rdf:RDF
   xmlns:gist="https://w3id.org/semanticarts/ns/ontology/gist/"
   xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
   xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
   xmlns:skos="http://www.w3.org/2004/02/skos/core#"
>
  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/conformsTo">
    <gist:rangeIncludes rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Intention"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">conforms to</rdfs:label>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">conforms to</skos:prefLabel>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: Meet an obligation; adhere to a specification or standard; meet terms and conditions of an offer; comply with a regulation.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: The subject is consistent with or satisfies the requirements, rules, or expectations established by the object.</rdfs:comment>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The subject is consistent with or satisfies the requirements, rules, or expectations established by the object.</skos:definition>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Meet an obligation; adhere to a specification or standard; meet terms and conditions of an offer; comply with a regulation.</skos:example>
  </rdf:Description>
</rdf:RDF>
