  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/isRenderedOn">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Relates content to the media on which it is rendered.</skos:definition>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A document is rendered on a computer screen; a piece of music is rendered through speakers.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: Relates content to the media on which it is rendered.</rdfs:comment>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is rendered on</skos:prefLabel>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A document is rendered on a computer screen; a piece of music is rendered through speakers.</skos:example>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">is rendered on</rdfs:label>
  </rdf:Description>
  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b283">
