  <rdf:Description rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b266">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Restriction"/>
    <owl:onProperty rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/hasMagnitude"/>
