    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unit of Measure</rdfs:label>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A standard amount used to measure or specify things.</skos:definition>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A standard amount used to measure or specify things.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: An acre is a unit for measuring area.</rdfs:comment>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An acre is a unit for measuring area.</skos:example>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Unit of Measure</skos:prefLabel>
  </rdf:Description>
