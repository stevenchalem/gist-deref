  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/hasPhysicalLocation">
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
