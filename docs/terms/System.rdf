  <rdf:Description rdf:about="https://w3id.org/semanticarts/ns/ontology/gist/System">
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">NOTE: May be used to refer to either man-made or natural systems.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">DEFINITION: A composite made up of interacting or interdependent components that together operate as a whole.</rdfs:comment>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">EXAMPLE: A manufacturing system, a storm system.</rdfs:comment>
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <skos:prefLabel rdf:datatype="http://www.w3.org/2001/XMLSchema#string">System</skos:prefLabel>
    <skos:example rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A manufacturing system, a storm system.</skos:example>
    <skos:scopeNote rdf:datatype="http://www.w3.org/2001/XMLSchema#string">May be used to refer to either man-made or natural systems.</skos:scopeNote>
    <rdfs:subClassOf rdf:resource="https://w3id.org/semanticarts/ns/ontology/gist/Composite"/>
    <skos:definition rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A composite made up of interacting or interdependent components that together operate as a whole.</skos:definition>
    <owl:equivalentClass rdf:nodeID="ndfd66d7f0f4d459a8ec599499a65c2e2b309"/>
    <rdfs:label rdf:datatype="http://www.w3.org/2001/XMLSchema#string">System</rdfs:label>
    <rdfs:isDefinedBy rdf:resource="https://w3id.org/semanticarts/ontology/gistCore14.1.0"/>
  </rdf:Description>
