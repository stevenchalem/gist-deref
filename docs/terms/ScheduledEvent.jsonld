  "@graph": [
    {
      "@id": "gist:ScheduledEvent",
      "@type": "owl:Class",
      "owl:equivalentClass": {
        "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b290"
      },
      "rdfs:comment": [
        "NOTE: If the event already started, but has not yet ended, it is a contemporary event with an actual start datetime. If the event is over, it is a historical event having an actual end datetime. The event always retains its planned start datetime, and thus continues to be a scheduled event.",
        "DEFINITION: An event with a planned start datetime."
      ],
      "rdfs:isDefinedBy": {
        "@id": "https://w3id.org/semanticarts/ontology/gistCore14.1.0"
      },
      "rdfs:label": "Scheduled Event",
      "rdfs:subClassOf": {
        "@id": "gist:Event"
      },
      "skos:definition": "An event with a planned start datetime.",
      "skos:prefLabel": "Scheduled Event",
      "skos:scopeNote": "If the event already started, but has not yet ended, it is a contemporary event with an actual start datetime. If the event is over, it is a historical event having an actual end datetime. The event always retains its planned start datetime, and thus continues to be a scheduled event."
    },
    {
      "@id": "_:ndfd66d7f0f4d459a8ec599499a65c2e2b290",
      "@type": "owl:Class",
      "owl:intersectionOf": {
